# SMTP Configuration for Nodemailer
# Copy this to .env.local and fill in your actual SMTP details

# Hostinger Email SMTP Configuration
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@digi-wire.com
SMTP_PASS=your-hostinger-email-password

# Alternative SMTP providers:
# For Gmail: smtp.gmail.com:587 (requires app password)
# For Outlook/Hotmail: smtp-mail.outlook.com:587
# For Yahoo: smtp.mail.yahoo.com:587
# For custom SMTP: your-smtp-server.com:587

# Note for Hostinger:
# 1. Use your Hostinger email address as SMTP_USER
# 2. Use your Hostinger email password as SMTP_PASS
# 3. Port 465 with SSL/TLS (secure connection)
# 4. Make sure SMTP access is enabled in your Hostinger control panel
